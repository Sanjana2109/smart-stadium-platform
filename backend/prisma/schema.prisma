generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  capacity  Int
  zones     Zone[]
}

model Zone {
  id        String   @id @default(cuid())
  name      String
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id])
  pois      Poi[]
}

model Poi {
  id          String   @id @default(cuid())
  name        String
  type        PoiType
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id])
  location    Json
}

enum PoiType {
  FOOD
  WASHROOM
  MERCH
  EXIT
}
